# ─── EpoShield — Apache Configuration ───────────────────────────────────────
# Handles: HTTPS redirect, 301 redirects from old Wix URLs, security headers,
# cache control, and gzip compression.
# ─────────────────────────────────────────────────────────────────────────────

Options -Indexes
RewriteEngine On

# ─── Force HTTPS ──────────────────────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── www → non-www (or reverse — pick one and comment out the other) ──────────
# Redirect www to non-www:
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ─── 301 Redirects from old Wix URLs ─────────────────────────────────────────
# Residential
RewriteRule ^residentialepoxyflooring/?$                                                                                         /residential-epoxy-flooring [R=301,L]

# Commercial / Industrial / Institutional (all pointed to same old page — now split)
RewriteRule ^epoxy-flooring-application-areas-of-service-toronto-commerical-institutional-industrial/?$                          /commercial-epoxy-flooring [R=301,L]
RewriteRule ^institutional/?$                /institutional-epoxy-flooring [R=301,L]
RewriteRule ^institutional-epoxy-flooring/?$ /institutional-epoxy-flooring [R=301,L]

# Coating Systems
RewriteRule ^concrete-epoxy-floor-coating-systems-polyaspartic-polyurethane-elastomeric-suspended-slab-water/?$                  /coating-systems [R=301,L]

# Quote / Contact
RewriteRule ^get-epoxy-flooring-estimate-quote-bid-contractor/?$                                                                 /get-a-quote [R=301,L]

# Other common Wix patterns
RewriteRule ^about/?$                        /about [R=301,L]
RewriteRule ^contact/?$                      /get-a-quote [R=301,L]
RewriteRule ^services/?$                     /residential-epoxy-flooring [R=301,L]
RewriteRule ^process/?$                      /coating-systems [R=301,L]
RewriteRule ^systems/?$                      /coating-systems [R=301,L]
RewriteRule ^gallery/?$                      /gallery [R=301,L]
RewriteRule ^blog/?$                         / [R=301,L]
RewriteRule ^blogs/?$                        / [R=301,L]

# ─── Clean URL → .html file ───────────────────────────────────────────────────
# Allows /residential-epoxy-flooring to serve residential-epoxy-flooring.html
RewriteCond %{REQUEST_FILENAME}      !-f
RewriteCond %{REQUEST_FILENAME}      !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$                /$1.html [L]

# ─── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options    "nosniff"
  Header always set X-Frame-Options           "SAMEORIGIN"
  Header always set X-XSS-Protection          "1; mode=block"
  Header always set Referrer-Policy           "strict-origin-when-cross-origin"
  Header always set Permissions-Policy        "camera=(), microphone=(), geolocation=()"
</IfModule>

# ─── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

# ─── Cache Control ────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: no cache (always fresh)
  ExpiresByType text/html                     "access plus 0 seconds"

  # CSS and JS: 1 year (use query string versioning when updating)
  ExpiresByType text/css                      "access plus 1 year"
  ExpiresByType application/javascript        "access plus 1 year"
  ExpiresByType text/javascript               "access plus 1 year"

  # Images: 6 months
  ExpiresByType image/webp                    "access plus 6 months"
  ExpiresByType image/avif                    "access plus 6 months"
  ExpiresByType image/jpeg                    "access plus 6 months"
  ExpiresByType image/png                     "access plus 6 months"
  ExpiresByType image/svg+xml                 "access plus 6 months"
  ExpiresByType image/x-icon                  "access plus 1 year"

  # Fonts: 1 year
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType font/woff                     "access plus 1 year"
</IfModule>

# ─── Error Pages ──────────────────────────────────────────────────────────────
ErrorDocument 404 /404.html
